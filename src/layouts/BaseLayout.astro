---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = 'KovaCo. Consulting',
  description = 'KovaCo. is a talent strategy practice for founders building early- and growth-stage companies.',
  ogImage     = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.kovaco.ca');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:type"        content="website" />
    <meta name="twitter:card"       content="summary_large_image" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Typography: Cormorant Garamond (editorial serif) + Inter (body sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Per-page head injections (JSON-LD, extra meta, etc.) -->
    <slot name="head" />
  </head>

  <body>
    <Header />
    <slot />
    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <p class="footer-logo">Kova<span>Co.</span> Consulting</p>
          <p class="footer-tagline">Talent strategy for founders building early- and growth-stage companies.</p>
        </div>
        <div>
          <p class="footer-col-label">Pages</p>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/articles">Articles</a></li>
            <li><a href="/impact">Impact</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-label">Start here</p>
          <ul class="footer-links">
            <li><a href="/contact">Contact</a></li>
            <li><a href="mailto:hello@kovaco.ca">hello@kovaco.ca</a></li>
            <li><a href="/services#audit">The Audit</a></li>
            <li><a href="/services#build">The Build</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="footer-copy">© 2026 KovaCo. Consulting · kovaco.ca</p>
        <p class="footer-territory">Built on the unceded territory of the syilx Okanagan people · Vernon, BC</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ─── Brand tokens ───────────────────────────────────────────── */
  :root {
    /* Authentic palette extracted from original site */
    --bg:         #F5F2ED;
    --text:       #1C1C1C;
    --sage:       #8FA088;
    --sage-light: #B5C4B0;
    --dark:       #1C1C1C;
    --mid:        #4A4A4A;
    --rule:       rgba(28, 28, 28, 0.12);

    /* Aliases used by utility classes */
    --color-bg:         var(--bg);
    --color-text:       var(--text);
    --color-text-muted: var(--mid);
    --color-accent:     var(--sage);
    --color-accent-dark:#5E7A58;
    --color-border:     var(--rule);
    --color-bg-alt:     #EDE9E2;
    --color-surface:    #FFFFFF;

    /* Fonts */
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans:  'Inter', system-ui, -apple-system, sans-serif;
    --mono:  'JetBrains Mono', 'Fira Code', monospace;

    /* Layout */
    --max:   1200px;
    --col:   680px;
    --nav-h: 72px;

    /* Fluid type scale */
    --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.875rem);
    --text-sm:   clamp(0.875rem, 0.82rem + 0.28vw, 1rem);
    --text-base: 1.125rem;   /* 18px — matches original */
    --text-lg:   clamp(1.125rem, 1rem + 0.6vw, 1.375rem);
    --text-xl:   clamp(1.25rem,  1.05rem + 1vw,  1.75rem);
    --text-2xl:  clamp(1.5rem,   1.1rem + 2vw,   2.5rem);
    --text-3xl:  clamp(1.875rem, 1.2rem + 3.4vw, 3.5rem);
    --text-4xl:  clamp(2.5rem,   1.5rem + 5vw,   5rem);
    --text-5xl:  clamp(2.75rem,  1.5rem + 6.5vw, 5.75rem);

    /* Spacing */
    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-5:  1.25rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;
    --space-24: 6rem;
    --space-32: 8rem;

    /* Derived layout helpers */
    --container-lg: var(--max);
    --container-md: var(--col);
    --site-padding: 40px;

    /* Motion */
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out:   cubic-bezier(0.4, 0, 0.2, 1);
    --duration-fast: 150ms;
    --duration-base: 200ms;
    --duration-enter:600ms;
  }

  /* ─── Reset ─────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: var(--text-base);
    line-height: 1.7;
    min-height: 100dvh;
    overflow-x: hidden;
  }

  img, video, svg { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; font: inherit; border: none; background: none; }
  ul, ol { list-style: none; }

  /* ─── Typography ─────────────────────────────────────────────── */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--serif);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: var(--text);
    text-wrap: balance;
  }

  p {
    line-height: 1.75;
    color: var(--text);
    text-wrap: pretty;
  }

  p + p { margin-top: var(--space-4); }

  strong, b { font-weight: 600; }
  em, i { font-style: italic; }

  /* ─── Layout utilities ───────────────────────────────────────── */
  .container {
    width: 100%;
    max-width: var(--max);
    margin-inline: auto;
    padding-inline: var(--site-padding);
  }
  .narrow {
    max-width: var(--col);
    margin-inline: auto;
  }
  .section {
    padding-block: clamp(var(--space-16), 8vw, var(--space-32));
  }
  .section--sm {
    padding-block: clamp(var(--space-8), 4vw, var(--space-16));
  }

  /* Eyebrow / label */
  .label, .section-label, .page-eyebrow {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
  }

  /* ─── Buttons ────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: var(--text);
    color: var(--bg);
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--sage); }
  .btn-primary .arrow { transition: transform 0.2s; }
  .btn-primary:hover .arrow { transform: translateX(4px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
    border-bottom: 1px solid var(--text);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--sage); border-color: var(--sage); }

  /* Legacy alias — keeps existing index.astro styles working */
  .btn, .link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition: color var(--duration-fast) var(--ease-in-out),
                border-color var(--duration-fast) var(--ease-in-out);
  }
  .btn:hover, .link:hover { color: var(--sage); border-color: currentColor; }
  .btn--primary { background: var(--text); color: var(--bg); border: none; padding: 12px 24px; }
  .btn--primary:hover { background: var(--sage); }
  .btn--ghost { border: 1px solid var(--rule); padding: 10px 20px; }
  .btn--ghost:hover { border-color: var(--text); }

  /* ─── Dividers ───────────────────────────────────────────────── */
  hr {
    border: none;
    border-top: 1px solid var(--rule);
    margin-block: var(--space-8);
  }

  /* ─── Prose (Markdown content) ───────────────────────────────── */
  .prose { max-width: var(--col); }

  .prose h2, .prose h3, .prose h4 {
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .prose p, .prose ul, .prose ol { margin-bottom: 1.25em; }
  .prose ul, .prose ol { padding-left: 1.5em; list-style: revert; }

  .prose a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--sage);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  .prose a:hover { text-decoration-color: var(--text); }

  .prose blockquote {
    border-left: 2px solid var(--sage);
    padding-left: var(--space-6);
    margin-left: 0;
    font-family: var(--serif);
    font-size: var(--text-xl);
    line-height: 1.4;
    color: var(--mid);
    font-style: italic;
  }
  .prose code {
    font-family: var(--mono);
    font-size: 0.875em;
    background: var(--color-bg-alt);
    padding: 0.1em 0.4em;
    border-radius: 3px;
  }

  /* ─── Scroll-driven reveal animations ───────────────────────── */
  @supports (animation-timeline: view()) {
    .reveal {
      animation: reveal-up linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 35%;
    }
    .reveal--delay-1 { animation-delay: 80ms; }
    .reveal--delay-2 { animation-delay: 160ms; }
    .reveal--delay-3 { animation-delay: 240ms; }
    .reveal--delay-4 { animation-delay: 320ms; }

    @keyframes reveal-up {
      from { opacity: 0; translate: 0 2rem; filter: blur(2px); }
      to   { opacity: 1; translate: 0 0;    filter: blur(0); }
    }

    .reveal-group > * {
      animation: reveal-up linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 35%;
    }
    .reveal-group > *:nth-child(1) { animation-delay:   0ms; }
    .reveal-group > *:nth-child(2) { animation-delay:  80ms; }
    .reveal-group > *:nth-child(3) { animation-delay: 160ms; }
    .reveal-group > *:nth-child(4) { animation-delay: 240ms; }
    .reveal-group > *:nth-child(5) { animation-delay: 320ms; }
    .reveal-group > *:nth-child(6) { animation-delay: 400ms; }
  }

  @supports not (animation-timeline: view()) {
    .reveal, .reveal-group > * {
      opacity: 0;
      transform: translateY(2rem);
      transition: opacity var(--duration-enter) var(--ease-out-expo),
                  transform var(--duration-enter) var(--ease-out-expo);
    }
    .reveal.is-visible, .reveal-group.is-visible > * {
      opacity: 1; transform: translateY(0);
    }
  }

  /* ─── View Transitions ───────────────────────────────────────── */
  ::view-transition-old(root) {
    animation: 200ms var(--ease-in-out) both vt-fade-out,
               200ms var(--ease-in-out) both vt-slide-out;
  }
  ::view-transition-new(root) {
    animation: 200ms var(--ease-in-out) both vt-fade-in,
               200ms var(--ease-in-out) both vt-slide-in;
  }
  @keyframes vt-fade-out  { from { opacity: 1; } to { opacity: 0; } }
  @keyframes vt-fade-in   { from { opacity: 0; } to { opacity: 1; } }
  @keyframes vt-slide-out { from { translate: 0 0; } to { translate: 0 -0.75rem; } }
  @keyframes vt-slide-in  { from { translate: 0 0.75rem; } to { translate: 0 0; } }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
    ::view-transition-old(root), ::view-transition-new(root) { animation: none; }
  }

  /* ─── Footer ─────────────────────────────────────────────────── */
  .site-footer {
    background: var(--dark);
    color: var(--bg);
    padding: 64px 0 40px;
  }
  .footer-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
  }
  .footer-logo {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--bg);
    margin-bottom: 12px;
  }
  .footer-logo span { color: var(--sage-light); }
  .footer-tagline {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(245,242,237,0.55);
    max-width: 240px;
  }
  .footer-col-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,242,237,0.4);
    margin-bottom: 20px;
  }
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-links a {
    font-size: 15px;
    color: rgba(245,242,237,0.7);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--bg); }
  .footer-bottom {
    max-width: var(--max);
    margin: 48px auto 0;
    padding: 24px 40px 0;
    border-top: 1px solid rgba(245,242,237,0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-copy     { font-size: 13px; color: rgba(245,242,237,0.35); }
  .footer-territory {
    font-size: 13px;
    color: rgba(245,242,237,0.35);
    text-align: right;
    max-width: 380px;
  }

  /* ─── Global interactive ─────────────────────────────────────── */
  ::selection { background: var(--sage); color: var(--bg); }

  :focus-visible {
    outline: 2px solid var(--sage);
    outline-offset: 3px;
    border-radius: 2px;
  }

  ::-webkit-scrollbar        { width: 6px; }
  ::-webkit-scrollbar-track  { background: var(--bg); }
  ::-webkit-scrollbar-thumb  { background: var(--rule); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--mid); }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    :root { --site-padding: 24px; }

    .footer-inner { grid-template-columns: 1fr 1fr; padding: 0 24px; }
    .footer-bottom {
      flex-direction: column; gap: 12px;
      text-align: center; padding: 24px 24px 0;
    }
    .footer-territory { text-align: center; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>

<script>
  /* Fallback IntersectionObserver for browsers without scroll-driven animations */
  if (!CSS.supports('animation-timeline', 'view()')) {
    const observe = () => {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal, .reveal-group').forEach(el => io.observe(el));
    };
    observe();
    document.addEventListener('astro:page-load', observe);
  }
</script>
