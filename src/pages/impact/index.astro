---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('success');
---

<BaseLayout
  title="Proven Impact & Client Stories | KovaCo. Consulting"
  description="Read what happens when scaling companies build disciplined hiring infrastructure. Case studies and client testimonials from KovaCo. talent strategy engagements."
>

  <header class="impact-header">
    <div class="impact-header-inner reveal-group">
      <p class="page-eyebrow">Impact</p>
      <h1 class="impact-heading">What it looks like when it works.</h1>
      <p class="impact-lead">
        The data behind successful organizational growth isn't measured in positions filled.
        True impact is found in the operational yield, retention milestones, and permanent
        hiring capability your team retains long after our engagement concludes.
      </p>
    </div>
  </header>

  <main class="impact-feature-section">
    <div class="impact-feature-inner">
      {entries.map(entry => (
        <article class="impact-feature reveal">
          <div class="impact-feature__quote-mark" aria-hidden="true">"</div>
          <blockquote class="impact-feature__snippet">
            {entry.data.snippet}
          </blockquote>
          <footer class="impact-feature__footer">
            <div class="impact-feature__meta">
              <p class="impact-feature__author">{entry.data.author}</p>
              <p class="impact-feature__role">{entry.data.title}</p>
              <p class="impact-feature__company">{entry.data.company}</p>
            </div>
            <a href={`/impact/${entry.id}`} class="impact-feature__cta btn-ghost">
              Read the full story <span aria-hidden="true">→</span>
            </a>
          </footer>
        </article>
      ))}
    </div>
  </main>

  <!-- CLOSING CTA -->
  <section class="impact-cta reveal">
    <div class="impact-cta-inner">
      <hr class="impact-cta-rule" />
      <h2 class="impact-cta-heading">Scale with Predictable Infrastructure</h2>
      <p class="impact-cta-body">
        We partner with founders to turn talent acquisition from an operational bottleneck
        into a competitive multiplier. Let's design a framework built for your velocity.
      </p>
      <a
        href="https://calendly.com/hello-kovaco/30min"
        class="btn-primary"
        target="_blank"
        rel="noopener"
      >
        Book an intro call <span class="arrow">→</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Header ─────────────────────────────────────────────────── */
  .impact-header {
    padding: 100px 40px 80px;
    border-bottom: 1px solid var(--rule);
  }
  .impact-header-inner {
    max-width: 720px;
    margin: 0 auto;
    display: grid;
    gap: 24px;
  }
  .impact-heading {
    font-family: var(--serif);
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-top: 8px;
  }
  .impact-lead {
    font-size: 17px;
    line-height: 1.75;
    color: var(--mid);
    max-width: 58ch;
  }

  /* ─── Feature testimonial ────────────────────────────────────── */
  .impact-feature-section {
    padding: 80px 40px 60px;
    border-bottom: 1px solid var(--rule);
  }
  .impact-feature-inner {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    gap: 48px;
  }

  .impact-feature {
    display: grid;
    gap: 32px;
    padding: 64px 72px;
    background: var(--color-bg-alt);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--sage);
  }

  .impact-feature__quote-mark {
    font-family: var(--serif);
    font-size: 96px;
    line-height: 0.55;
    color: var(--sage);
    opacity: 0.45;
    user-select: none;
  }

  .impact-feature__snippet {
    font-family: var(--serif);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: var(--text);
    quotes: none;
    max-width: 56ch;
  }

  .impact-feature__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
  }

  .impact-feature__author {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text);
    margin-bottom: 5px;
  }
  .impact-feature__role {
    font-size: 14px;
    color: var(--mid);
    margin-bottom: 3px;
  }
  .impact-feature__company {
    font-size: 13px;
    color: var(--sage);
    letter-spacing: 0.03em;
  }

  .impact-feature__cta { flex-shrink: 0; }

  /* ─── Closing CTA ────────────────────────────────────────────── */
  .impact-cta {
    padding: 100px 40px 120px;
  }
  .impact-cta-inner {
    max-width: 640px;
    margin: 0 auto;
    display: grid;
    gap: 24px;
    justify-items: start;
  }
  .impact-cta-rule {
    border: none;
    border-top: 1px solid var(--rule);
    width: 100%;
    margin-bottom: 16px;
  }
  .impact-cta-heading {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .impact-cta-body {
    font-size: 17px;
    line-height: 1.75;
    color: var(--mid);
    max-width: 52ch;
  }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .impact-header        { padding: 72px 24px 64px; }
    .impact-feature-section { padding: 64px 24px 48px; }
    .impact-feature       { padding: 44px 36px; }
    .impact-cta           { padding: 72px 24px 80px; }
    .impact-feature__footer { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .impact-feature { padding: 32px 24px; }
  }
</style>
