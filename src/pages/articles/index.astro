---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('articles');
const sorted  = entries.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Articles & Strategic Insights | KovaCo. Consulting"
  description="In-depth frameworks, field notes, and tactical talent strategy blueprints for early-stage founders by Adrienne Kovacs."
>

  <header class="articles-header">
    <div class="articles-header-inner reveal-group">
      <p class="page-eyebrow">Articles</p>
      <h1 class="articles-heading">Thinking out loud, in writing.</h1>
      <p class="articles-lead">
        Frameworks, field notes, and architectural perspectives from inside early- and
        growth-stage scaling. No superficial advice — only the objective models a founder
        needs to read before making a critical hiring mistake.
      </p>
    </div>
  </header>

  <main class="articles-list-section">
    <div class="articles-list-inner">
      <ul class="articles-list reveal-group" role="list">
        {sorted.map(entry => (
          <li class="article-card">
            <a href={`/articles/${entry.id}`} class="article-card__link">
              <div class="article-card__meta">
                <time class="article-card__date" datetime={entry.data.pubDate.toISOString()}>
                  {entry.data.pubDate.toLocaleDateString('en-CA', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </time>
              </div>
              <h2 class="article-card__title">{entry.data.title}</h2>
              <p class="article-card__description">{entry.data.description}</p>
              <span class="article-card__cta" aria-hidden="true">Read the article →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>

</BaseLayout>

<style>
  /* ─── Header ─────────────────────────────────────────────────── */
  .articles-header {
    padding: 100px 40px 80px;
    border-bottom: 1px solid var(--rule);
  }
  .articles-header-inner {
    max-width: var(--max);
    margin: 0 auto;
    display: grid;
    gap: 24px;
    max-width: 720px;
  }
  .articles-heading {
    font-family: var(--serif);
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-top: 8px;
  }
  .articles-lead {
    font-size: 17px;
    line-height: 1.75;
    color: var(--mid);
    max-width: 56ch;
  }

  /* ─── List ───────────────────────────────────────────────────── */
  .articles-list-section { padding: 0 40px 100px; }
  .articles-list-inner   { max-width: var(--max); margin: 0 auto; }

  .articles-list {
    display: grid;
    list-style: none;
  }

  .article-card {
    border-top: 1px solid var(--rule);
  }
  .article-card:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .article-card__link {
    display: grid;
    gap: 12px;
    padding: 48px 0;
    transition: opacity 0.2s;
  }
  .article-card__link:hover .article-card__title { color: var(--sage); }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .article-card__date {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
  }
  .article-card__title {
    font-family: var(--serif);
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
    transition: color 0.2s;
    max-width: 820px;
  }
  .article-card__description {
    font-size: 16px;
    line-height: 1.7;
    color: var(--mid);
    max-width: 64ch;
  }
  .article-card__cta {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    align-self: start;
    transition: color 0.2s, border-color 0.2s;
  }
  .article-card__link:hover .article-card__cta {
    color: var(--sage);
    border-color: var(--sage);
  }

  @media (max-width: 900px) {
    .articles-header        { padding: 72px 24px 64px; }
    .articles-list-section  { padding: 0 24px 72px; }
    .article-card__link     { padding: 36px 0; }
  }
</style>
