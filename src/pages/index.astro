---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="KovaCo. | Talent Strategy & Recruitment Architecture for Founders"
  description="High-impact talent strategy practice by Adrienne Kovacs. We design custom recruitment infrastructure, structured interview systems, and executive search for scaling companies."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "KovaCo. Consulting",
    "url": "https://www.kovaco.ca",
    "logo": "https://www.kovaco.ca/favicon.svg",
    "description": "Talent strategy consultancy for founders. Hiring audits, fractional recruiting, and senior search for early-stage companies.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vernon",
      "addressRegion": "BC",
      "addressCountry": "CA"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Canada"
    },
    "serviceType": ["Talent Strategy", "Recruitment Consulting", "Fractional Recruiting", "Executive Search"],
    "knowsAbout": ["Talent Acquisition", "Hiring Process Design", "Startup Recruiting", "Executive Search"],
    "sameAs": []
  })} />

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="section hero">
    <div class="container container--lg">
      <div class="hero__inner reveal-group">
        <span class="label">KovaCo. Consulting</span>
        <h1 class="hero__headline">
          Hiring is how a company <em class="hero__decides">decides</em> what it's going to become.
        </h1>
        <div class="hero__body">
          <p>
            KovaCo. is a talent strategy practice designed for founders navigating
            early- and growth-stage scale. We partner with building teams to engineer
            disciplined hiring architecture, execute critical executive searches, and
            design robust talent infrastructure that compounds as your enterprise grows.
          </p>
          <p class="hero__body-accent">
            Build internal hiring capability before rapid growth exposes the absence of it.
          </p>
        </div>
        <a href="https://calendly.com/hello-kovaco/30min" class="btn btn--primary hero__cta" target="_blank" rel="noopener">
          Book an intro call →
        </a>
      </div>
    </div>
  </section>

  <hr class="container container--lg" />

  <!-- ─── Services ─────────────────────────────────────────────── -->
  <section class="section services">
    <div class="container container--lg">

      <div class="services__header reveal">
        <span class="label">The Long-Term Infrastructure</span>
      </div>

      <div class="service reveal">
        <div class="service__header">
          <span class="label">01</span>
          <h2 class="service__title">Audit</h2>
        </div>
        <div class="service__body">
          <p>
            A structured, objective review of how your company currently hires
            to locate process drag and structural vulnerabilities.
          </p>
          <p class="service__impact">
            <strong>Impact:</strong> Founders typically cut time-to-hire by
            30–50% and reduce mis-hires within the first two pipeline cycles.
          </p>
        </div>
        <a href="/services" class="link service__link">See the work →</a>
      </div>

      <hr />

      <div class="service reveal">
        <div class="service__header">
          <span class="label">02</span>
          <h2 class="service__title">Build</h2>
        </div>
        <div class="service__body">
          <p>
            Designing the custom hiring capability your team runs long-term —
            including structured interview frameworks and assessment scorecards.
          </p>
          <p class="service__impact">
            <strong>Impact:</strong> Clients who complete the Build engagement
            reduce external agency spend by an average of 60% in the following
            twelve months.
          </p>
        </div>
        <a href="/services" class="link service__link">See the work →</a>
      </div>

      <hr />

      <div class="service reveal">
        <div class="service__header">
          <span class="label">03</span>
          <h2 class="service__title">Advise</h2>
        </div>
        <div class="service__body">
          <p>
            Ongoing strategic guidance for founders navigating high-stakes
            organizational design, scaling thresholds, and leadership appointments.
          </p>
          <p class="service__impact">
            <strong>Impact:</strong> Advise clients report stronger retention
            at the 12-month mark and measurably faster ramp times for new
            executive hires.
          </p>
        </div>
        <a href="/services" class="link service__link">See the work →</a>
      </div>

    </div>
  </section>

  <!-- ─── Search wedge ──────────────────────────────────────────── -->
  <section class="search-wedge reveal">
    <div class="container container--lg">
      <div class="search-wedge__inner">
        <div class="search-wedge__flag">
          <span class="search-wedge__flag-label">Strategic Intervention</span>
        </div>
        <div class="search-wedge__content">
          <h2 class="search-wedge__title">Senior &amp; Specialized Search</h2>
          <p class="search-wedge__body">
            For organizations facing immediate, critical leadership bottlenecks.
            We undertake discrete, standalone executive and hyper-specialized
            searches to find the exact personnel required to define your business
            direction. You do not need an active consulting engagement to deploy
            our search capabilities.
          </p>
          <a
            href="https://calendly.com/hello-kovaco/30min"
            class="search-wedge__cta btn-primary"
            target="_blank"
            rel="noopener"
          >
            Start a search <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Testimonial snippet ─────────────────────────────────── -->
  <section class="section section--sm testimonial-strip">
    <div class="container container--lg">
      <div class="testimonial-strip__inner reveal">
        <div class="testimonial-strip__quote-mark" aria-hidden="true">"</div>
        <blockquote class="testimonial-strip__snippet">
          Adrienne built the tools and systems necessary to support our rapid expansion… She brings a strong, strategic project management lens to her work and excels at building relationships. Businesses expanding across the country would be lucky to have her.
        </blockquote>
        <footer class="testimonial-strip__footer">
          <div class="testimonial-strip__meta">
            <span class="testimonial-strip__author">Amanda Carling, JD</span>
            <span class="testimonial-strip__role">Former CEO / Co-Founder · BC First Nations Justice Council</span>
          </div>
          <a href="/impact/amanda-carling" class="testimonial-strip__link">Read the full story →</a>
        </footer>
      </div>
    </div>
  </section>

  <!-- ─── Articles teaser ─────────────────────────────────────── -->
  <section class="section section--sm articles-teaser">
    <div class="container container--lg">
      <div class="articles-teaser__inner reveal-group">
        <span class="label">Articles</span>
        <h2 class="articles-teaser__headline">Thinking out loud, in writing.</h2>
        <p>Frameworks, field notes, and hard-won perspective from inside early-stage hiring.</p>
        <a href="/articles" class="btn-ghost">Read all articles <span>→</span></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ───────────────────────────────────────────────────── */
  .hero__inner {
    display: grid;
    gap: var(--space-8);
    max-width: 780px;
  }

  .hero__headline {
    font-size: var(--text-4xl);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-top: var(--space-3);
  }

  .hero__decides {
    font-style: italic;
    color: #8FA088;
  }

  .hero__body {
    display: grid;
    gap: var(--space-4);
    max-width: 62ch;
  }

  .hero__body p {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  .hero__body-accent {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text) !important;
    border-left: 2px solid var(--sage);
    padding-left: var(--space-6);
    margin-top: var(--space-2);
  }

  .hero__cta {
    align-self: start;
    margin-top: var(--space-2);
  }

  /* Tighten hero → services gap (global .section is too generous here) */
  .hero    { padding-block-end:   clamp(var(--space-8), 4vw, var(--space-12)); }
  .services { padding-block-start: clamp(var(--space-8), 4vw, var(--space-12)); }

  /* ─── Services ───────────────────────────────────────────────── */
  .services .container {
    display: grid;
    gap: var(--space-2);
  }

  .service {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-block: var(--space-10);
  }

  @media (min-width: 768px) {
    .service {
      grid-template-columns: 260px 1fr auto;
      align-items: start;
      gap: var(--space-12);
    }
  }

  .service__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service__title {
    font-size: var(--text-3xl);
    margin-top: var(--space-1);
  }

  .service__body {
    display: grid;
    gap: var(--space-4);
  }

  .service__body p {
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .service__impact {
    color: var(--color-text) !important;
    font-size: var(--text-sm) !important;
    padding: var(--space-4);
    border-left: 2px solid var(--color-accent);
    background: var(--color-bg-alt);
  }

  .service__link {
    align-self: start;
    white-space: nowrap;
    margin-top: var(--space-1);
  }

  /* ─── Services header label ──────────────────────────────────── */
  .services__header {
    padding-bottom: var(--space-2);
  }

  /* ─── Search wedge ───────────────────────────────────────────── */
  .search-wedge {
    background: var(--text);
    color: var(--bg);
    padding-block: clamp(var(--space-16), 8vw, var(--space-24));
  }

  .search-wedge__inner {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .search-wedge__flag {
    padding-top: 6px;
  }
  .search-wedge__flag-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage-light);
    border-top: 1px solid rgba(181,196,176,0.3);
    padding-top: 12px;
  }

  .search-wedge__content {
    display: grid;
    gap: var(--space-6);
  }

  .search-wedge__title {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: var(--bg);
  }

  .search-wedge__body {
    font-size: 17px;
    line-height: 1.75;
    color: rgba(245,242,237,0.75);
    max-width: 58ch;
  }

  .search-wedge__cta {
    align-self: start;
    justify-self: start;
    background: var(--sage);
    color: var(--bg);
  }
  .search-wedge__cta:hover { background: var(--sage-light); }

  @media (max-width: 768px) {
    .search-wedge__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* ─── Testimonial strip ─────────────────────────────────────── */
  .testimonial-strip__inner {
    display: grid;
    gap: 28px;
    max-width: 820px;
    margin: 0 auto;
    padding: 52px 56px;
    border: 1px solid var(--rule);
    background: var(--color-bg-alt);
  }
  .testimonial-strip__quote-mark {
    font-family: var(--serif);
    font-size: 72px;
    line-height: 0.6;
    color: var(--sage);
    opacity: 0.5;
    user-select: none;
  }
  .testimonial-strip__snippet {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.55;
    color: var(--text);
    quotes: none;
  }
  .testimonial-strip__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }
  .testimonial-strip__author {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }
  .testimonial-strip__role {
    display: block;
    font-size: 13px;
    color: var(--mid);
  }
  .testimonial-strip__link {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s, border-color 0.2s;
  }
  .testimonial-strip__link:hover { color: var(--sage); border-color: var(--sage); }

  @media (max-width: 720px) {
    .testimonial-strip__inner { padding: 36px 28px; }
    .testimonial-strip__footer { flex-direction: column; align-items: flex-start; }
  }

  /* ─── Articles teaser ───────────────────────────────────────── */
  .articles-teaser__inner {
    display: grid;
    gap: var(--space-5);
    max-width: 640px;
  }
  .articles-teaser__headline {
    font-size: var(--text-3xl);
    line-height: 1.1;
    margin-top: var(--space-2);
  }
  .articles-teaser__inner p { color: var(--color-text-muted); }
</style>
